{
  "manifest_version": 3,
  "name": "Local PDF OCR",
  "version": "0.1.0",
  "description": "OCR scanned PDFs locally using a local FastAPI backend.",

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },

  "permissions": ["activeTab", "tabs"],

  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],

  "action": {
    "default_title": "Local PDF OCR",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_popup": "popup.html"
  }
}