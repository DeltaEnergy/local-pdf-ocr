{
  "manifest_version": 3,
  "name": "Local PDF OCR",
  "version": "0.1.0",
  "description": "OCR scanned PDFs locally using a local FastAPI backend.",
  "permissions": ["activeTab", "tabs"],
  "host_permissions": ["http://127.0.0.1:8000/*", "http://localhost:8000/*"],
  "action": {
    "default_popup": "popup.html"
  }
}